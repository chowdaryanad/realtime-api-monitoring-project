      "type": "stat",
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"rtam-api\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
