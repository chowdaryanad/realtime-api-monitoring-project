# =============================================================================
# Real-Time API Monitoring — Environment Configuration (EXAMPLE)
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit secrets to version control.

# Application
APP_NAME=rtam-api
APP_ENV=development
APP_DEBUG=true
API_PORT=8000
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=rtam_user
POSTGRES_PASSWORD=<YOUR_SECURE_PASSWORD>
POSTGRES_DB=rtam_db
POSTGRES_PORT=5432

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# Grafana
GRAFANA_PORT=3000
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=<YOUR_SECURE_PASSWORD>
GF_ROOT_URL=http://localhost:3000

# Alertmanager
ALERTMANAGER_PORT=9093

# Loki
LOKI_PORT=3100
